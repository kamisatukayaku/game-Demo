{
  "schema_version": 2,
  "_note": "节点图事件格式。新增战斗圈事件、诅咒祭坛、灵魂契约等。所有可获得饰品的非诅咒事件都要求付出代价。",
  "events": [
    {
      "id": "event_sacrifice_hp",
      "display_name": "生命献祭",
      "description": "一个古老的祭坛出现在你面前。",
      "category": "sacrifice",
      "min_world_level": 1,
      "is_repeatable": false,
      "weight": 1.5,
      "nodes": [
        { "node_id": "start", "description": "祭坛散发着诡异的光芒，石板上的文字要求你献祭生命力来换取力量。", "options": [
          { "text": "献祭 25% 生命", "next": "sacrifice" },
          { "text": "无视祭坛离开", "next": "end" }
        ]},
        { "node_id": "sacrifice", "description": "你割破手掌，鲜血滴入祭坛的凹槽...", "condition": { "type": "hp_percent", "op": "gte", "value": 30 },
          "effects": [{ "type": "modify_hp", "value": -0.25, "value_type": "percent" }],
          "options": [
            { "text": "祈求力量(+15%攻击)", "next": "reward_attack" },
            { "text": "祈求生命(+20%最大HP)", "next": "reward_hp" },
            { "text": "祈求财富(+300金币)", "next": "reward_gold" }
          ]},
        { "node_id": "reward_attack", "description": "祭坛回应了你的祈求，力量涌入你的身体。", "effects": [{ "type": "add_attribute", "attr": "attack_mult", "value": 0.15 }], "auto_next": "end" },
        { "node_id": "reward_hp", "description": "暖流流过全身，你的生命力显著增强。", "effects": [{ "type": "add_attribute", "attr": "max_hp_mult", "value": 0.20 }], "auto_next": "end" },
        { "node_id": "reward_gold", "description": "祭坛底部打开，露出了堆积的金币。", "effects": [{ "type": "modify_gold", "value": 300 }], "auto_next": "end" },
        { "node_id": "end", "description": "你继续踏上旅途。" }
      ]
    },
    {
      "id": "event_reveal_camps",
      "display_name": "制高点侦察",
      "description": "你发现了一处制高点，可以俯瞰周围的营地分布。",
      "category": "intel",
      "min_world_level": 1,
      "is_repeatable": true,
      "weight": 1.0,
      "nodes": [
        { "node_id": "start", "description": "攀上高处，你能看到附近的营地布局。是否花时间观察？", "options": [
          { "text": "侦察附近（+80 XP，显示营地）", "next": "scout" },
          { "text": "不浪费时间", "next": "end" }
        ]},
        { "node_id": "scout", "description": "你仔细观察了周围地形，标记了所有营地的位置。", "effects": [
          { "type": "modify_xp", "value": 80 },
          { "type": "reveal_markers", "marker_type": "Camp" }
        ], "auto_next": "end" },
        { "node_id": "end", "description": "继续前进。" }
      ]
    },
    {
      "id": "event_treasure_cache",
      "display_name": "隐藏宝藏",
      "description": "你在废墟中发现了一个隐藏的补给箱。",
      "category": "treasure",
      "min_world_level": 2,
      "is_repeatable": false,
      "weight": 1.2,
      "nodes": [
        { "node_id": "start", "description": "箱子看起来有些年头了，但锁扣仍然完好。", "options": [
          { "text": "撬开宝箱（获得破损饰品）", "next": "accessory" },
          { "text": "小心检查（+200 金币 + 50 XP）", "next": "gold_xp" },
          { "text": "离开", "next": "end" }
        ]},
        { "node_id": "accessory", "description": "在箱子夹层中，你发现了一件饰品。", "effects": [{ "type": "add_accessory", "rarity": "damaged", "count": 1 }], "auto_next": "end" },
        { "node_id": "gold_xp", "description": "箱子里装满了金币和一些古代文献。", "effects": [
          { "type": "modify_gold", "value": 200 },
          { "type": "modify_xp", "value": 50 }
        ], "auto_next": "end" },
        { "node_id": "end", "description": "离开废墟。" }
      ]
    },
    {
      "id": "event_risky_trade",
      "display_name": "神秘交易",
      "description": "一个身披斗篷的神秘商人拦住了你。",
      "category": "risk_reward",
      "min_world_level": 3,
      "is_repeatable": true,
      "weight": 1.0,
      "nodes": [
        { "node_id": "start", "description": "\"我有稀有货品，但需要你付出代价。\"商人低声说。", "options": [
          { "text": "消耗 200 XP 换攻击Buff", "next": "xp_trade", "condition": { "type": "player_level", "op": "gte", "value": 3 } },
          { "text": "消耗 150 金币换移速Buff", "next": "gold_trade", "condition": { "type": "gold", "op": "gte", "value": 150 } },
          { "text": "消耗15%HP换完好饰品", "next": "hp_trade", "condition": { "type": "hp_percent", "op": "gte", "value": 20 } },
          { "text": "拒绝交易", "next": "end" }
        ]},
        { "node_id": "xp_trade", "description": "商人取走了经验精华，递给你一瓶发光药剂。", "effects": [
          { "type": "modify_xp", "value": -200 },
          { "type": "apply_buff", "buff_id": "shop_buff_attack_boost", "duration": 120 }
        ], "auto_next": "end" },
        { "node_id": "gold_trade", "description": "商人收下金币，在你手背上画了符文。", "effects": [
          { "type": "modify_gold", "value": -150 },
          { "type": "apply_buff", "buff_id": "shop_buff_speed_boost", "duration": 150 }
        ], "auto_next": "end" },
        { "node_id": "hp_trade", "description": "商人取走了你的血液，递给你一件完好饰品。", "effects": [
          { "type": "modify_hp", "value": -0.15, "value_type": "percent" },
          { "type": "add_accessory", "rarity": "intact", "count": 1 }
        ], "auto_next": "end" },
        { "node_id": "end", "description": "商人消失在阴影中。" }
      ]
    },
    {
      "id": "event_challenge_trial",
      "display_name": "试炼挑战",
      "description": "远古守护者的幻影向你发起挑战。",
      "category": "challenge",
      "min_world_level": 5,
      "is_repeatable": false,
      "weight": 0.8,
      "nodes": [
        { "node_id": "start", "description": "\"只有真正的勇士才配得到我的馈赠。\"", "options": [
          { "text": "接受试炼（-20%HP，+精致饰品）", "next": "accept", "condition": { "type": "hp_percent", "op": "gte", "value": 30 } },
          { "text": "谨慎撤退", "next": "end" }
        ]},
        { "node_id": "accept", "description": "守护者洒下光环，你的身体承受了试炼。", "effects": [
          { "type": "modify_hp", "value": -0.20, "value_type": "percent" },
          { "type": "add_accessory", "rarity": "refined", "count": 1 }
        ], "auto_next": "reward_xp" },
        { "node_id": "reward_xp", "description": "守护者满意地点头。", "effects": [{ "type": "modify_xp", "value": 200 }], "auto_next": "end" },
        { "node_id": "end", "description": "守护者的幻影消散。" }
      ]
    },
    {
      "id": "event_combat_circle",
      "display_name": "战斗圈",
      "description": "一个魔法屏障突然升起，将你困在其中！只有击败所有出现的敌人才可离开。",
      "category": "challenge",
      "min_world_level": 5,
      "is_repeatable": true,
      "weight": 0.9,
      "nodes": [
        { "node_id": "start", "description": "魔法符文在地面亮起，形成一个限制圈。\"战斗至死，或荣耀而归！\"", "options": [
          { "text": "迎战！（生成一批敌人+限制圈，获胜得完好饰品）", "next": "fight" },
          { "text": "在屏障完全封闭前逃离（消耗50金币）", "next": "flee", "condition": { "type": "gold", "op": "gte", "value": 50 } }
        ]},
        { "node_id": "fight", "description": "敌人从四面八方涌来！", "effects": [
          { "type": "spawn_combat_circle", "enemy_count": 5, "radius": 10.0 }
        ], "options": [
          { "text": "战斗胜利！", "next": "victory" }
        ]},
        { "node_id": "victory", "description": "最后一名敌人倒下，屏障随之消散。", "effects": [
          { "type": "add_accessory", "rarity": "intact", "count": 1 },
          { "type": "modify_xp", "value": 100 }
        ], "auto_next": "end" },
        { "node_id": "flee", "description": "你仓促逃离，损失了一些金币。", "effects": [{ "type": "modify_gold", "value": -50 }], "auto_next": "end" },
        { "node_id": "end", "description": "战斗的余音在空中回荡。" }
      ]
    },
    {
      "id": "event_xp_wager",
      "display_name": "经验赌局",
      "description": "路边出现了一个古老的赌局机关。",
      "category": "risk_reward",
      "min_world_level": 6,
      "is_repeatable": true,
      "weight": 0.9,
      "nodes": [
        { "node_id": "start", "description": "\"押上经验，翻转命运\"。两个按钮：红与蓝。", "options": [
          { "text": "押上 150 XP", "next": "gamble", "condition": { "type": "player_level", "op": "gte", "value": 4 } },
          { "text": "安全起见", "next": "end" }
        ]},
        { "node_id": "gamble", "description": "你按下按钮...", "effects": [{ "type": "modify_xp", "value": -150 }], "options": [
          { "text": "红色", "next": "win" },
          { "text": "蓝色", "next": "lose" }
        ]},
        { "node_id": "win", "description": "铃声！赌赢了！获得300 XP + 完好饰品！", "effects": [
          { "type": "modify_xp", "value": 300 },
          { "type": "add_accessory", "rarity": "intact", "count": 1 }
        ], "auto_next": "end" },
        { "node_id": "lose", "description": "低鸣声...赌输了。", "effects": [{ "type": "modify_xp", "value": -80 }], "auto_next": "end" },
        { "node_id": "end", "description": "机关缓缓沉入地下。" }
      ]
    },
    {
