{
  "schema_version": 3,
  "_note": "Boss = 多个正多边形/棱角形组合；可 solid 或 outline。无曲线。见 docs/art-enemies-and-bosses.md",
  "rendering": {
    "projection": "orthographic_2d",
    "top_down_perspective": false,
    "outline_width_px": 1,
    "outline_thick_px": 2.5
  },
  "defaults": {
    "part_fill_rule": "solid",
    "curves_allowed": false
  },
  "wild_bosses": [
    {
      "id": "wild_boss_hex_king",
      "gameplay_archetype_id": "mob_pent_01",
      "visual_scale": 2.6,
      "palette": "wild_boss",
      "parts": [
        { "role": "core", "shape_id": "hex", "fill_rule": "solid", "offset": [0, 0], "scale": 1.0, "rotation_deg": 0, "spin_deg_per_sec": 0 },
        { "role": "satellite", "shape_id": "tri", "fill_rule": "outline", "offset": [0, 1.1], "scale": 0.48, "rotation_deg": 0, "spin_deg_per_sec": 0 },
        { "role": "satellite", "shape_id": "tri", "fill_rule": "outline", "offset": [1.1, 0], "scale": 0.48, "rotation_deg": 90, "spin_deg_per_sec": 0 },
        { "role": "satellite", "shape_id": "tri", "fill_rule": "outline", "offset": [0, -1.1], "scale": 0.48, "rotation_deg": 180, "spin_deg_per_sec": 0 },
        { "role": "satellite", "shape_id": "tri", "fill_rule": "outline", "offset": [-1.1, 0], "scale": 0.48, "rotation_deg": 270, "spin_deg_per_sec": 0 },
        { "role": "ring", "shape_id": "oct", "fill_rule": "outline_thick", "offset": [0, 0], "scale": 1.35, "rotation_deg": 22.5, "spin_deg_per_sec": -8 }
      ],
      "animation": { "core_breath": 0.04, "satellite_wobble_deg": 5 },
      "exports": {
        "hex_king_part":    { "include_roles": ["ring"], "_comment": "八边形外环 → 护盾部件" },
        "hex_king_phantom": { "include_roles": ["core", "satellite", "ring"], "visual_scale_override": 2.2, "alpha_mult": 0.55, "exclude_from_main": false, "_comment": "幻影（缩小+半透明，不影响主体）" }
      }
    },
    {
      "id": "wild_boss_pent_colossus",
      "gameplay_archetype_id": "mob_pent_01",
      "visual_scale": 2.75,
      "palette": "wild_boss",
      "parts": [
        { "role": "core", "shape_id": "pent", "fill_rule": "solid", "offset": [0, 0], "scale": 1.0, "rotation_deg": 0, "spin_deg_per_sec": 0 },
        { "role": "crown", "shape_id": "tri", "fill_rule": "outline", "offset": [0, 1.05], "scale": 0.52, "rotation_deg": 0, "spin_deg_per_sec": 0 },
        { "role": "subpart", "shape_id": "square", "fill_rule": "solid", "offset": [-1.05, 0.15], "scale": 0.5, "rotation_deg": 12, "spin_deg_per_sec": 0 },
        { "role": "subpart", "shape_id": "square", "fill_rule": "solid", "offset": [1.05, 0.15], "scale": 0.5, "rotation_deg": -12, "spin_deg_per_sec": 0 },
        { "role": "satellite", "shape_id": "hept", "fill_rule": "outline", "offset": [0, -0.95], "scale": 0.42, "rotation_deg": 0, "spin_deg_per_sec": 14 }
      ],
      "animation": { "core_breath": 0.03, "satellite_wobble_deg": 4 },
      "exports": {
        "pent_colossus_part": { "include_roles": ["subpart"], "_comment": "正方形子部件 → 具有血量的弹幕部件" }
      }
    },
    {
      "id": "wild_boss_star_hive",
      "gameplay_archetype_id": "mob_pent_01",
      "visual_scale": 2.5,
      "palette": "wild_boss_mutant",
      "parts": [
        { "role": "core", "shape_id": "star5", "fill_rule": "solid", "offset": [0, 0], "scale": 1.0, "rotation_deg": 0, "spin_deg_per_sec": 0 },
        { "role": "satellite", "shape_id": "hex", "fill_rule": "outline", "offset": [0, 1.25], "scale": 0.42, "rotation_deg": 0, "spin_deg_per_sec": -10 },
        { "role": "satellite", "shape_id": "hex", "fill_rule": "outline", "offset": [1.08, -0.62], "scale": 0.42, "rotation_deg": 0, "spin_deg_per_sec": -10 },
        { "role": "satellite", "shape_id": "hex", "fill_rule": "outline", "offset": [-1.08, -0.62], "scale": 0.42, "rotation_deg": 0, "spin_deg_per_sec": -10 },
        { "role": "ring", "shape_id": "star6", "fill_rule": "outline_thick", "offset": [0, 0], "scale": 1.28, "rotation_deg": 0, "spin_deg_per_sec": 12 }
      ],
      "animation": { "core_breath": 0.05, "satellite_wobble_deg": 8 }
    }
  ],
  "final_boss": {
    "id": "final_boss_prism_nexus",
    "visual_scale": 3.5,
    "palette": "final_boss",
    "parts": [
      { "role": "core", "shape_id": "hex", "fill_rule": "solid", "offset": [0, 0], "scale": 1.2, "rotation_deg": 0, "spin_deg_per_sec": 0 },
      { "role": "inner", "shape_id": "diamond", "fill_rule": "outline", "offset": [0, 0], "scale": 0.72, "rotation_deg": 0, "spin_deg_per_sec": -20 },
      { "role": "satellite", "shape_id": "square", "fill_rule": "outline", "offset": [0, 0.95], "scale": 0.48, "rotation_deg": 0, "spin_deg_per_sec": 0 },
      { "role": "satellite", "shape_id": "square", "fill_rule": "outline", "offset": [0.82, -0.47], "scale": 0.48, "rotation_deg": 120, "spin_deg_per_sec": 0 },
      { "role": "satellite", "shape_id": "square", "fill_rule": "outline", "offset": [-0.82, -0.47], "scale": 0.48, "rotation_deg": 240, "spin_deg_per_sec": 0 },
      { "role": "ring", "shape_id": "tri", "fill_rule": "solid", "offset": [0, 1.65], "scale": 0.36, "rotation_deg": 0, "spin_deg_per_sec": 18 },
      { "role": "ring", "shape_id": "tri", "fill_rule": "solid", "offset": [1.43, 0.82], "scale": 0.36, "rotation_deg": 60, "spin_deg_per_sec": 18 },
      { "role": "ring", "shape_id": "tri", "fill_rule": "solid", "offset": [1.43, -0.82], "scale": 0.36, "rotation_deg": 120, "spin_deg_per_sec": 18 },
      { "role": "ring", "shape_id": "tri", "fill_rule": "solid", "offset": [0, -1.65], "scale": 0.36, "rotation_deg": 180, "spin_deg_per_sec": 18 },
      { "role": "ring", "shape_id": "tri", "fill_rule": "solid", "offset": [-1.43, -0.82], "scale": 0.36, "rotation_deg": 240, "spin_deg_per_sec": 18 },
      { "role": "ring", "shape_id": "tri", "fill_rule": "solid", "offset": [-1.43, 0.82], "scale": 0.36, "rotation_deg": 300, "spin_deg_per_sec": 18 },
      { "role": "halo", "shape_id": "dodec", "fill_rule": "outline_thick", "offset": [0, 0], "scale": 1.55, "rotation_deg": 15, "spin_deg_per_sec": -6 }
    ],
    "phases": [
      { "hp_percent_above": 0.66, "core_shape_id": "hex", "inner_fill_rule": "outline", "ring_spin_mult": 1.0 },
      { "hp_percent_above": 0.33, "core_shape_id": "oct", "ring_shape_id": "star4", "inner_fill_rule": "outline_thick", "ring_spin_mult": 1.5 },
      { "hp_percent_above": 0.0, "core_shape_id": "hexagram", "ring_shape_id": "star4", "inner_fill_rule": "outline_thick", "ring_spin_mult": 2.0 }
    ],
    "animation": { "core_breath": 0.035, "satellite_wobble_deg": 3 },
    "exports": {
      "prism_nexus_ring":  { "include_roles": ["ring"], "_comment": "三角形弹幕部件" },
      "prism_nexus_part":  { "include_roles": ["halo"], "_comment": "12边型护盾部件" }
    }
  },
  "palettes": {
    "wild_boss": {
      "fill": "#D47858",
      "outline": "#FFFFFF",
      "outline_thick": "#FFFFFF",
      "satellite_fill_mult": 0.88
    },
    "wild_boss_mutant": {
      "fill": "#C88858",
      "outline": "#FFFFFF",
      "outline_thick": "#FFFFFF",
      "satellite_fill_mult": 0.85
    },
    "final_boss": {
      "fill": "#E8E0F0",
      "outline": "#483858",
      "outline_thick": "#A898C8",
      "ring_fill": "#A898C8"
    }
  },
  "shapes_ref": "enemy_visuals.json"
}
